# Supabase (BS-22). Скопируй в .env и подставь значения из Supabase → Project Settings → API.
# EXPO_PUBLIC_* инлайнятся в web-бандл при сборке. anon-ключ ПУБЛИЧНЫЙ по дизайну —
# доступ к данным ограничивает RLS (см. scripts/supabase-setup.sql). Хранить как секрет не нужно,
# но в CI кладём в GitHub Actions secrets, чтобы не хардкодить в репозитории.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Старое (архив бота) — не используется приложением:
# TELEGRAM_BOT_TOKEN=
# ANTHROPIC_API_KEY=
